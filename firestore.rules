rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Land rates - readable by anyone, writable only by Cloud Functions
    match /landRates/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Users collection - allow register and login
    match /users/{phone} {
      allow read, write: if true;
    }

    // Digital Twins - land registrations
    match /digitalTwins/{landId} {
      allow read, write: if true;
    }
  }
}
